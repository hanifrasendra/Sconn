<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- TOP NAVBAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:id="@+id/menu">

        <ImageButton
            android:id="@+id/btn_menu"
            android:layout_width="18dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_menu"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitXY"
            android:layout_marginStart="20dp"
            app:layout_constraintTop_toTopOf="@id/tv_app_name"
            app:layout_constraintBottom_toBottomOf="@id/tv_app_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_app_name"/>

        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SConn"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#6B6B2A"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_menu"
            android:layout_marginStart="8dp"/>

        <ImageButton
            android:id="@+id/btn_search_top"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            android:scaleType="fitXY"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginEnd="20dp"
            app:layout_constraintTop_toTopOf="@id/btn_menu"
            app:layout_constraintBottom_toBottomOf="@id/btn_menu"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>


    <!-- SCROLLABLE CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/menu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <!-- GREETING -->
            <TextView
                android:id="@+id/tv_study_connection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STUDY CONNECTION"
                android:textSize="12sp"
                android:textColor="#6B6B6B"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tv_hello"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Hello, Alex!"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#1C1C0E"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@id/tv_study_connection"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/iv_avatar"/>

            <ImageView
                android:id="@+id/iv_avatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop"
                app:layout_constraintTop_toTopOf="@id/tv_study_connection"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- SEARCH BAR -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:id="@+id/et_search"
                android:background="@drawable/search_bar"
                android:gravity="center_vertical"
                android:paddingHorizontal="19dp"
                app:layout_constraintTop_toBottomOf="@id/tv_hello"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_search"
                    android:id="@+id/search_ic"
                    android:scaleType="fitXY"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/search"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <EditText
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:id="@+id/search"
                    android:hint="Search partners or places..."
                    android:textColorHint="#9E9E9E"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:drawablePadding="10dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="10dp"
                    app:layout_constraintStart_toEndOf="@id/search_ic"/>

            </androidx.constraintlayout.widget.ConstraintLayout>


            <!-- QUICK ACTION CARDS -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_find_partners"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/et_search"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/card_browse_places">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ic_partners"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_find_partners"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/tv_find_partners"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <TextView
                        android:id="@+id/tv_find_partners"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Find Partners"
                        android:textSize="13sp"
                        android:textColor="#1C1C0E"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/ic_partners"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_browse_places"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_marginTop="20dp"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/et_search"
                app:layout_constraintStart_toEndOf="@id/card_find_partners"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ic_places"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_browse_places"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/tv_browse_places"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <TextView
                        android:id="@+id/tv_browse_places"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Browse Places"
                        android:textSize="13sp"
                        android:textColor="#1C1C0E"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/ic_places"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- RECOMMENDED PARTNERS HEADER -->
            <TextView
                android:id="@+id/tv_recommended_partners"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recommended Partners"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1C1C0E"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/card_find_partners"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tv_see_all_partners"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SEE ALL"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#6B6B2A"
                app:layout_constraintTop_toTopOf="@id/tv_recommended_partners"
                app:layout_constraintBottom_toBottomOf="@id/tv_recommended_partners"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- PARTNER CARDS ROW -->
            <LinearLayout
                android:id="@+id/ll_partners"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/tv_recommended_partners"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Partner Card 1 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="2dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/iv_partner1"
                            android:layout_width="match_parent"
                            android:layout_height="140dp"
                            android:src="@drawable/img_partner1"
                            android:scaleType="centerCrop"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="95% Match"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:background="@drawable/bg_match_badge"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="8dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp"
                            android:layout_gravity="bottom"
                            android:layout_marginTop="140dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sarah Jenkins"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1C1C0E"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Biology Major"
                                android:textSize="12sp"
                                android:textColor="#6B6B6B"/>
                        </LinearLayout>
                    </FrameLayout>
                </androidx.cardview.widget.CardView>

                <!-- Partner Card 2 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="2dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/iv_partner2"
                            android:layout_width="match_parent"
                            android:layout_height="140dp"
                            android:src="@drawable/img_partner2"
                            android:scaleType="centerCrop"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="92% Match"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:background="@drawable/bg_match_badge"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="8dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp"
                            android:layout_gravity="bottom"
                            android:layout_marginTop="140dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Liam Chen"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1C1C0E"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Comp Sci Major"
                                android:textSize="12sp"
                                android:textColor="#6B6B6B"/>
                        </LinearLayout>
                    </FrameLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- RECOMMENDED PLACES HEADER -->
            <TextView
                android:id="@+id/tv_recommended_places"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recommended Places"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1C1C0E"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/ll_partners"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tv_see_all_places"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SEE ALL"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#6B6B2A"
                app:layout_constraintTop_toTopOf="@id/tv_recommended_places"
                app:layout_constraintBottom_toBottomOf="@id/tv_recommended_places"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- PLACE CARD 1 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_place1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/tv_recommended_places"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/img_place1"
                        android:scaleType="centerCrop"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Central Library"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1C1C0E"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="★ 4.8"
                                android:textSize="13sp"
                                android:textColor="#6B6B2A"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quiet Zone • 0.2 miles away"
                            android:textSize="13sp"
                            android:textColor="#6B6B6B"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- PLACE CARD 2 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_place2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/card_place1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/img_place2"
                        android:scaleType="centerCrop"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Central Library"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1C1C0E"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="★ 4.8"
                                android:textSize="13sp"
                                android:textColor="#6B6B2A"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quiet Zone • 0.2 miles away"
                            android:textSize="13sp"
                            android:textColor="#6B6B6B"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- PLACE CARD 3 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_place3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/card_place2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/img_place3"
                        android:scaleType="centerCrop"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Canvas Coffee"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1C1C0E"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="★ 4.5"
                                android:textSize="13sp"
                                android:textColor="#6B6B2A"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Social Hub • 0.5 miles away"
                            android:textSize="13sp"
                            android:textColor="#6B6B6B"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM NAVIGATION -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:menu="@menu/bottom_nav_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>