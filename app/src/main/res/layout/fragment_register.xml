<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".RegisterFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- Header: SConn + X -->
        <TextView
            android:id="@+id/app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SConn"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#6B6B2A"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"/>

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <!-- Title -->
        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Begin your journey"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1C1C0E"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/app_name"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Connect with study partners who share your academic vision."
            android:textSize="14sp"
            android:textColor="#6B6B6B"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <!-- Full Name Label -->
        <TextView
            android:id="@+id/full_name_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FULL NAME"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1C1C0E"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/subtitle"
            app:layout_constraintLeft_toLeftOf="parent"/>

        <!-- Full Name Input -->
        <EditText
            android:id="@+id/et_full_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Alex Rivers"
            android:textColorHint="#9E9E9E"
            android:textSize="16sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:drawableStart="@android:drawable/ic_menu_myplaces"
            android:drawablePadding="12dp"
            android:layout_marginTop="8dp"
            android:inputType="textPersonName"
            app:layout_constraintTop_toBottomOf="@id/full_name_label"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <!-- Major Study Label -->
        <TextView
            android:id="@+id/major_study_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MAJOR STUDY"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1C1C0E"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/et_full_name"
            app:layout_constraintLeft_toLeftOf="parent"/>

        <!-- Major Study Input -->
        <EditText
            android:id="@+id/et_major_study"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Computer Science"
            android:textColorHint="#9E9E9E"
            android:textSize="16sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="8dp"
            android:inputType="text"
            app:layout_constraintTop_toBottomOf="@id/major_study_label"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <!-- Associate Label -->
        <TextView
            android:id="@+id/associate_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ASSOCIATE / UNIVERSITY"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1C1C0E"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/et_major_study"
            app:layout_constraintLeft_toLeftOf="parent"/>

        <!-- Associate Input -->
        <EditText
            android:id="@+id/et_associate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="University of Indonesia"
            android:textColorHint="#9E9E9E"
            android:textSize="16sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:layout_marginTop="8dp"
            android:inputType="text"
            app:layout_constraintTop_toBottomOf="@id/associate_label"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <!-- Email Label -->
        <TextView
            android:id="@+id/email_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMAIL ADDRESS"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1C1C0E"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/et_associate"
            app:layout_constraintLeft_toLeftOf="parent"/>

        <!-- Email Input -->
        <EditText
            android:id="@+id/et_email"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="alex.rivers@university.edu"
            android:textColorHint="#9E9E9E"
            android:textSize="16sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:drawableStart="@android:drawable/ic_dialog_email"
            android:drawablePadding="12dp"
            android:layout_marginTop="8dp"
            android:inputType="textEmailAddress"
            app:layout_constraintTop_toBottomOf="@id/email_label"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <!-- Password Label -->
        <TextView
            android:id="@+id/password_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PASSWORD"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#1C1C0E"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/et_email"
            app:layout_constraintLeft_toLeftOf="parent"/>

        <!-- Password Input -->
        <EditText
            android:id="@+id/et_password"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="* * * * *"
            android:textColorHint="#9E9E9E"
            android:textSize="16sp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp"
            android:drawablePadding="12dp"
            android:layout_marginTop="8dp"
            android:inputType="textPassword"
            app:layout_constraintTop_toBottomOf="@id/password_label"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <!-- Continue Button -->
        <Button
            android:id="@+id/btn_register"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:text="Regis"
            android:textSize="18sp"
            android:textColor="#6B6B2A"
            android:backgroundTint="#F5F0A0"
            android:layout_marginTop="40dp"
            app:cornerRadius="100dp"
            app:layout_constraintTop_toBottomOf="@id/et_password"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>